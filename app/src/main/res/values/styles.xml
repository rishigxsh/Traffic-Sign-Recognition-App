<resources>
    <style name="TextAppearance.TSR.AppLabel" parent="">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#111111</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.TSR.ScreenTitle" parent="">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#111111</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.03</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.TSR.ScreenSubtitle" parent="">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.TSR.SectionLabel" parent="">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.TSR.CardTitle" parent="">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#111111</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.TSR.CardTitle.Small" parent="@style/TextAppearance.TSR.CardTitle">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.TSR.CardTitle.OnDark" parent="@style/TextAppearance.TSR.CardTitle">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.TSR.Body" parent="">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.TSR.Body.OnDark" parent="@style/TextAppearance.TSR.Body">
        <item name="android:textColor">@color/home_text_on_dark</item>
    </style>

    <style name="TextAppearance.TSR.MetricValue" parent="">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">#111111</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.TSR.MetricLabel" parent="">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
