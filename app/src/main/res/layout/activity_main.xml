<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".ui.main.MainActivity">

    <!-- 1. Center Area: Full Screen Camera View -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay bounding boxes -->
    <com.example.tsrapp.ui.main.DetectionOverlayView
        android:id="@+id/detectionOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan-line grid overlay (visible only while scanning) -->
    <View
        android:id="@+id/scanGridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/scan_grid"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. Top Banner: Apple Maps Navigation Style -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBannerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#00000000"
        app:cardElevation="8dp"
        app:cardCornerRadius="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_floating_card"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <!-- Primary detected sign icon -->
            <FrameLayout
                android:id="@+id/signBadgeFrame"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_sign_badge">

                <TextView
                    android:id="@+id/signBadgeSymbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:text="" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/detectedSignName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Searching..."
                    android:textColor="#1a1a1a"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/detectedSignType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detecting traffic signs"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Confidence / Priority label -->
            <TextView
                android:id="@+id/detectedConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/tsr_speed"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3. Side Controls: Floating Buttons on Right -->
    <LinearLayout
        android:id="@+id/sideControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/topBannerCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanelCard">

        <ImageButton
            android:id="@+id/muteButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_floating_circle"
            android:src="@drawable/ic_unmute"
            android:elevation="4dp"
            android:contentDescription="Mute Voice Alerts"
            app:tint="#1a1a1a" />

        <ImageButton
            android:id="@+id/stopButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_floating_circle"
            android:src="@drawable/ic_stop"
            android:elevation="4dp"
            android:contentDescription="Stop Detection"
            app:tint="#cc0000" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintTop_toBottomOf="@id/topBannerCard"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/white" />

    <!-- 4. Bottom Panel: Controls & Metrics -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomPanelCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#00000000"
        app:cardElevation="8dp"
        app:cardCornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_floating_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threshold"
                android:textColor="#444444"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <SeekBar
                    android:id="@+id/thresholdSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progress="20"
                    android:max="95"
                    android:splitTrack="false" />

                <TextView
                    android:id="@+id/statusThreshold"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="20%"
                    android:textAlignment="viewEnd"
                    android:textColor="#1a1a1a"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statusFps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1a1a1a"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FPS"
                        android:textColor="#666666"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/statusInference"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#1a1a1a"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inference"
                        android:textColor="#666666"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/toggleDetectionButton"
                    android:layout_width="140dp"
                    android:layout_height="52dp"
                    android:text="START"
                    android:fontFamily="sans-serif-black"
                    app:cornerRadius="26dp"
                    app:backgroundTint="@color/tsr_navy" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
