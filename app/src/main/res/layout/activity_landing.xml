<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_landing_screen"
    android:padding="24dp"
    tools:context=".ui.main.LandingActivity">

    <View
        android:id="@+id/orbTop"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.6"
        android:background="@drawable/bg_landing_orb_blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/orbBottom"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:alpha="0.45"
        android:background="@drawable/bg_landing_orb_gold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#14000000"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/landingEyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/landing_eyebrow"
                android:textAllCaps="true"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.22" />

            <TextView
                android:id="@+id/landingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/landing_title"
                android:textColor="@color/white"
                android:textSize="42sp"
                android:fontFamily="sans-serif-black"
                android:lineSpacingExtra="6sp" />

            <TextView
                android:id="@+id/landingSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/landing_subtitle"
                android:textColor="#E5FFFFFF"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:minHeight="56dp"
                android:paddingStart="26dp"
                android:paddingEnd="26dp"
                android:text="@string/landing_cta"
                android:textAllCaps="false"
                android:textColor="@color/tsr_navy"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:elevation="0dp"
                app:backgroundTint="@color/white"
                app:cornerRadius="28dp"
                app:insetTop="0dp"
                app:insetBottom="0dp"
                app:rippleColor="#33000000" />

            <TextView
                android:id="@+id/bottomHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/landing_hint"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
