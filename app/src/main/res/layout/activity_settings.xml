<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_surface_bg"
    android:fillViewport="true"
    tools:context=".ui.main.SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/tsr_space_2xl">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/tsr_space_xl"
            android:paddingTop="@dimen/tsr_space_lg">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="@dimen/tsr_header_icon"
                android:layout_height="@dimen/tsr_header_icon"
                android:background="@drawable/bg_ui_top_icon_tile"
                android:contentDescription="@string/back_to_home"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/tsr_text_primary" />

            <TextView
                android:id="@+id/appName"
                style="@style/TextAppearance.TSR.AppLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/tsr_space_md"
                android:text="@string/app_name"
                app:layout_constraintBottom_toBottomOf="@id/backButton"
                app:layout_constraintEnd_toStartOf="@id/appLogo"
                app:layout_constraintStart_toEndOf="@id/backButton"
                app:layout_constraintTop_toTopOf="@id/backButton" />

            <ImageView
                android:id="@+id/appLogo"
                android:layout_width="@dimen/tsr_header_icon"
                android:layout_height="@dimen/tsr_header_icon"
                android:background="@drawable/bg_ui_top_icon_tile"
                android:contentDescription="@string/app_name"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/tsrlogo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/tsr_space_xl"
            android:paddingTop="28dp"
            android:paddingBottom="@dimen/tsr_space_xl">

            <TextView
                style="@style/TextAppearance.TSR.ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title" />

            <TextView
                style="@style/TextAppearance.TSR.ScreenSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tsr_space_xs"
                android:text="@string/settings_subtitle" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TSR.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/tsr_space_xl"
            android:text="@string/settings_detection_header" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_lg"
            android:layout_marginTop="@dimen/tsr_space_sm"
            android:layout_marginEnd="@dimen/tsr_space_lg"
            android:background="@drawable/bg_home_secondary_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/tsr_space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_home_icon_teal"
                    android:gravity="center"
                    android:text="🔊"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/tsr_space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.TSR.CardTitle.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_voice_label" />

                    <TextView
                        style="@style/TextAppearance.TSR.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_voice_desc" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/ttsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testTtsButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/tsr_space_sm"
                android:text="@string/settings_tts_test_button"
                android:textAllCaps="false"
                android:textColor="@color/tsr_navy"
                app:cornerRadius="@dimen/tsr_radius_md"
                app:strokeColor="@color/home_badge_border" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/tsr_space_md"
                android:layout_marginBottom="@dimen/tsr_space_md"
                android:background="@color/home_badge_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_home_icon_slate"
                    android:gravity="center"
                    android:text="⚠️"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/tsr_space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.TSR.CardTitle.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_alerts_label" />

                    <TextView
                        style="@style/TextAppearance.TSR.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_alerts_desc" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/showBoxesSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/tsr_space_md"
                android:layout_marginBottom="@dimen/tsr_space_md"
                android:background="@color/home_badge_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_home_icon_slate"
                    android:gravity="center"
                    android:text="🌙"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/tsr_space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.TSR.CardTitle.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_night_label" />

                    <TextView
                        style="@style/TextAppearance.TSR.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_night_desc" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/nightModeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TSR.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_xl"
            android:layout_marginTop="@dimen/tsr_space_xl"
            android:text="@string/settings_region_header" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_lg"
            android:layout_marginTop="@dimen/tsr_space_sm"
            android:layout_marginEnd="@dimen/tsr_space_lg"
            android:background="@drawable/bg_home_secondary_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/tsr_space_xl">

            <TextView
                style="@style/TextAppearance.TSR.CardTitle.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_region_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tsr_space_md"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/regionEu"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_active"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="@string/settings_region_eu"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/regionUs"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_inactive"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="@string/settings_region_us"
                    android:textAllCaps="false"
                    android:textColor="@color/tsr_text_secondary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/regionAsia"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_inactive"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="@string/settings_region_asia"
                    android:textAllCaps="false"
                    android:textColor="@color/tsr_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TSR.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_xl"
            android:layout_marginTop="@dimen/tsr_space_xl"
            android:text="@string/settings_model_header" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_lg"
            android:layout_marginTop="@dimen/tsr_space_sm"
            android:layout_marginEnd="@dimen/tsr_space_lg"
            android:background="@drawable/bg_home_secondary_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/tsr_space_xl">

            <TextView
                style="@style/TextAppearance.TSR.CardTitle.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_model_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tsr_space_md"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/modelCnnV2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_active"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="CNN v2.1"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/modelCnnV1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_inactive"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="CNN v1.8"
                    android:textAllCaps="false"
                    android:textColor="@color/tsr_text_secondary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/modelLite"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/tsr_space_xs"
                    android:layout_weight="1"
                    android:background="@drawable/bg_region_inactive"
                    android:fontFamily="sans-serif-black"
                    android:stateListAnimator="@null"
                    android:text="Lite v2.0"
                    android:textAllCaps="false"
                    android:textColor="@color/tsr_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TSR.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_xl"
            android:layout_marginTop="@dimen/tsr_space_xl"
            android:text="@string/settings_conf_threshold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_lg"
            android:layout_marginTop="@dimen/tsr_space_sm"
            android:layout_marginEnd="@dimen/tsr_space_lg"
            android:background="@drawable/bg_home_secondary_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/tsr_space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextAppearance.TSR.CardTitle.Small"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_conf_threshold" />

                <TextView
                    android:id="@+id/confidenceValue"
                    style="@style/TextAppearance.TSR.CardTitle.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50%" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/confidenceSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tsr_space_sm"
                android:stepSize="5"
                android:value="50"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="@color/tsr_navy"
                app:trackColorActive="@color/tsr_navy"
                app:trackColorInactive="@color/home_badge_border" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TSR.SectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_xl"
            android:layout_marginTop="@dimen/tsr_space_xl"
            android:text="@string/settings_about_subtitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/tsr_space_lg"
            android:layout_marginTop="@dimen/tsr_space_sm"
            android:layout_marginEnd="@dimen/tsr_space_lg"
            android:background="@drawable/bg_home_secondary_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="@dimen/tsr_space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_ui_top_icon_tile"
                    android:contentDescription="@string/app_name"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/tsrlogo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/tsr_space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.TSR.CardTitle.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_about_version" />

                    <TextView
                        style="@style/TextAppearance.TSR.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_about_subtitle" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.TSR.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tsr_space_md"
                android:text="@string/settings_about_detail" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
