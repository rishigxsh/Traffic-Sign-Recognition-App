<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_surface_bg"
    tools:context=".ui.main.HomeActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/tsr_space_2xl">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/tsr_space_xl"
                android:paddingTop="@dimen/tsr_space_lg">

                <TextView
                    android:id="@+id/appName"
                    style="@style/TextAppearance.TSR.AppLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    app:layout_constraintBottom_toBottomOf="@id/appLogo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/appLogo" />

                <ImageView
                    android:id="@+id/appLogo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_ui_top_icon_tile"
                    android:contentDescription="@string/app_name"
                    android:padding="7dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/tsrlogo"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/tsr_space_xl"
                android:paddingTop="@dimen/tsr_space_xl"
                android:paddingBottom="@dimen/tsr_space_lg">

                <TextView
                    style="@style/TextAppearance.TSR.ScreenTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_title" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/tsr_space_sm"
                    android:background="@drawable/bg_home_badge"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_home_badge_dot" />

                    <TextView
                        style="@style/TextAppearance.TSR.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/home_subtitle"
                        android:textColor="#5A5A6E"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/startButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/tsr_margin_default"
                android:background="@drawable/bg_home_primary_card"
                android:clickable="true"
                android:elevation="6dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:minHeight="@dimen/tsr_home_card_min_height"
                android:padding="@dimen/tsr_space_xl">

                <FrameLayout
                    android:id="@+id/iconFrame"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_home_primary_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/home_live_detection"
                        android:src="@drawable/ic_home_camera" />
                </FrameLayout>

                <TextView
                    android:id="@+id/cardTitle"
                    style="@style/TextAppearance.TSR.CardTitle.OnDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/tsr_space_lg"
                    android:text="@string/home_live_detection"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iconFrame" />

                <TextView
                    android:id="@+id/cardDesc"
                    style="@style/TextAppearance.TSR.Body.OnDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/home_live_detection_desc"
                    android:textColor="#8F90A6"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardTitle" />

                <LinearLayout
                    android:id="@+id/startScanActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="@dimen/tsr_space_xl"
                    android:background="@drawable/bg_home_primary_action"
                    android:clickable="false"
                    android:focusable="false"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardDesc"
                    app:layout_constraintVertical_bias="1.0">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/home_start_scanning"
                        android:src="@drawable/ic_home_play" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/home_start_scanning"
                        android:textColor="#2B2D42"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                style="@style/TextAppearance.TSR.SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/tsr_space_xl"
                android:layout_marginTop="20dp"
                android:text="@string/home_more_options"
                android:textAllCaps="false"
                android:textSize="14sp" />

